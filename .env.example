# Hotel Mediterranee Environment Variables
# Copy to .env and edit for your setup
# Never commit .env to git!

# Directory for data files (CSV/JSON)
DATA_DIR=.

# Database path (for init_db.py)
DB_PATH=hotel_mediterranee.db

# Streamlit config
STREAMLIT_PORT=8501
STREAMLIT_SERVER_HEADLESS=true

# Secrets (for future: API keys, etc.)
SECRET_KEY=your-secret-key-here
DB_PASSWORD=

# Cloudflare tunnel (if used)
TUNNEL_NAME=hotel-mediterranee
